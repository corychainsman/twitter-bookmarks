{
  "name": "twitter-bookmarks-media-browser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:ft": "FT_DATA_DIR=\"$PWD/.data/fieldtheory\" bun run scripts/sync-fieldtheory.ts",
    "sync:ft:resume": "FT_DATA_DIR=\"$PWD/.data/fieldtheory\" bun run scripts/sync-fieldtheory.ts",
    "sync:ft:full": "FT_DATA_DIR=\"$PWD/.data/fieldtheory\" bun run scripts/sync-fieldtheory.ts",
    "data:export": "bun run scripts/export-fieldtheory.ts",
    "data:embeddings": "bun run scripts/export-embeddings.ts",
    "data:validate": "bun run scripts/validate-export.ts",
    "refresh": "bun run sync:ft && bun run data:export && bun run data:embeddings && bun run data:validate && bun run build",
    "refresh:resume": "bun run sync:ft:resume && bun run data:export && bun run data:embeddings && bun run data:validate && bun run build",
    "refresh:full": "bun run sync:ft:full && bun run data:export && bun run data:embeddings && bun run data:validate && bun run build",
    "refresh:embeddings": "bun run sync:ft && bun run data:export && bun run data:embeddings && bun run data:validate && bun run build"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@huggingface/transformers": "^4.2.0",
    "@tanstack/react-router": "^1.168.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "minisearch": "^7.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtualized": "9.22.6",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "yet-another-react-lightbox": "^3.31.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-virtualized": "9.22.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "fieldtheory": "1.3.9",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
